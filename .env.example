# Social Research Probe — environment variables
#
# Copy this file to .env and fill in the values you need.
# Only variables relevant to your chosen features are required.

# ---------------------------------------------------------------------------
# Data platform keys
# ---------------------------------------------------------------------------

# YouTube Data API v3 key — required for YouTube search and metadata.
# Get one at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
SRP_YOUTUBE_API_KEY=

# ---------------------------------------------------------------------------
# Corroboration backends
#
# Corroboration cross-checks claims extracted from research results against
# external search engines. The system runs all configured backends and uses
# majority-vote aggregation, so more backends = more reliable verdicts.
# Configure at least one; all three together gives the strongest signal.
# When multiple keys are set, pass them all to the CLI:
#   srp corroborate-claims --backends brave,exa,tavily claims.json
#
# Brave  — traditional keyword web-index search (no AI generation). Best for
#           fact-checking concrete, specific claims (names, dates, statistics)
#           where you want a broad, unfiltered web signal. Use this if you only
#           want one backend.
#           Pricing: paid only — no free tier. See: https://brave.com/search/api/
#
# Exa    — AI-powered semantic search that matches by meaning rather than
#           keywords. Complements Brave by finding relevant sources even when
#           the exact wording of a claim does not appear verbatim in source
#           text. Use alongside Brave for nuanced or paraphrased claims.
#           Pricing: free tier with monthly credits; pay-as-you-go above that.
#           See: https://exa.ai/pricing
#
# Tavily — search API purpose-built for AI agents, with a different crawl
#           index from both Brave and Exa. Its main value is diversifying the
#           majority-vote pool: when Brave and Exa disagree, Tavily acts as a
#           tiebreaker. Add it when you want the most robust corroboration.
#           Pricing: free tier (1,000 credits/month); paid plans above that.
#           See: https://tavily.com/#pricing
# ---------------------------------------------------------------------------

# Brave Search API key — traditional web index, best single-backend choice (paid).
# Get one at: https://api.search.brave.com/app/keys
SRP_BRAVE_API_KEY=

# Exa search API key — semantic/AI search, pairs well with Brave.
# Get one at: https://dashboard.exa.ai/api-keys
SRP_EXA_API_KEY=

# Tavily search API key — AI-agent-optimised search, acts as tiebreaker.
# Get one at: https://app.tavily.com/home
SRP_TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# LLM runner (only needed when llm.runner = "local" in config.toml)
# ---------------------------------------------------------------------------

# Absolute path to a locally-hosted LLM binary (e.g. ollama, llama.cpp).
# The binary must accept a prompt via stdin and return plain text on stdout.
# Example: /usr/local/bin/ollama
SRP_LOCAL_LLM_BIN=

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------

# Override the data directory used for config, cache, and output.
# Defaults to .skill-data/ in the current directory, or ~/.social-research-probe/
# SRP_DATA_DIR=

# Browser to use for yt-dlp cookie authentication when YouTube blocks scraping.
# Accepted values: chrome, firefox, safari, edge, brave, chromium, opera, vivaldi
# Leave unset (or set to "none") to skip cookie injection.
# SRP_YTDLP_BROWSER=chrome
