# Social Research Probe environment variables
#
# Copy this file to .env only if your shell or launcher loads .env files. srp
# also reads these variables directly from the process environment. Secrets may
# alternatively be stored with `srp config set-secret <name>`.

# ---------------------------------------------------------------------------
# Data platform keys
# ---------------------------------------------------------------------------

# YouTube Data API v3 key. Required for live YouTube search and metadata fetches.
# This consumes Google quota units. Check the Google Cloud console for the
# current quota and billing behavior on your project.
# Secret-file equivalent: youtube_api_key
# Get one at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
SRP_YOUTUBE_API_KEY=

# ---------------------------------------------------------------------------
# Corroboration provider keys
# ---------------------------------------------------------------------------

# Brave Search API key. Used by the `brave` corroboration provider for keyword
# web-index search. Check Brave's dashboard for current plan and billing terms.
# Secret-file equivalent: brave_api_key
# Get one at: https://api.search.brave.com/app/keys
SRP_BRAVE_API_KEY=

# Exa API key. Used by the `exa` corroboration provider for semantic search,
# which helps find sources even when wording differs from the claim.
# Secret-file equivalent: exa_api_key
# Get one at: https://dashboard.exa.ai/api-keys
SRP_EXA_API_KEY=

# Tavily API key. Used by the `tavily` corroboration provider for agent-focused
# search and as an additional independent signal when providers disagree.
# Secret-file equivalent: tavily_api_key
# Get one at: https://app.tavily.com/home
SRP_TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# Local LLM runner
# ---------------------------------------------------------------------------

# Absolute path to a local LLM wrapper used only when [llm].runner = "local" and
# technologies.local = true. The wrapper must read the prompt from stdin and
# write the answer to stdout. Hosted CLIs such as Claude, Gemini, and Codex do
# not use this variable; they manage their own authentication outside srp.
# Example: /usr/local/bin/srp-local-llm
SRP_LOCAL_LLM_BIN=

# ---------------------------------------------------------------------------
# Data directory and cache controls
# ---------------------------------------------------------------------------

# Optional override for config, secrets, cache, charts, reports, and generated
# artifacts. When unset, srp uses .skill-data/ in the current repository if it
# exists, otherwise ~/.social-research-probe/.
# SRP_DATA_DIR=/Users/you/.social-research-probe

# Bypass on-disk technology caches under cache/technologies/*. Useful for
# benchmarking or forced refreshes.
# Accepts: 1, true, yes, on.
# SRP_DISABLE_CACHE=1

# Fast mode trades quality for first-run latency. It reduces enrichment depth,
# skips merged-summary reconciliation, and limits corroboration breadth.
# Accepts: 1, true, yes, on.
# SRP_FAST_MODE=1

# ---------------------------------------------------------------------------
# YouTube fallback media fetch
# ---------------------------------------------------------------------------

# Browser profile used by yt-dlp for cookies when YouTube blocks anonymous media
# fetching. Leave unset or set to "none" to skip browser-cookie injection.
# Accepted values include: chrome, firefox, safari, edge, brave, chromium,
# opera, vivaldi.
# SRP_YTDLP_BROWSER=chrome

# Path to a yt-dlp cookies.txt file. When set, this takes precedence over
# SRP_YTDLP_BROWSER.
# SRP_YTDLP_COOKIES_FILE=/absolute/path/to/cookies.txt

# ---------------------------------------------------------------------------
# Voicebox report playback and narration
# ---------------------------------------------------------------------------

# Base URL used by generated HTML reports and `srp serve-report` when proxying
# Voicebox browser playback requests.
# SRP_VOICEBOX_API_BASE=http://127.0.0.1:17493

# Secret/env override used by the Voicebox TTS technology when rendering audio
# narration outside the browser report flow.
# Secret-file equivalent: tts_voicebox_server_url
# SRP_TTS_VOICEBOX_SERVER_URL=http://127.0.0.1:17493

# Default Voicebox profile used by the TTS technology when no profile is passed
# by the report renderer.
# Secret-file equivalent: tts_voicebox_default_profile
# SRP_TTS_VOICEBOX_DEFAULT_PROFILE=Jarvis

# ---------------------------------------------------------------------------
# Diagnostics
# ---------------------------------------------------------------------------

# Enable stderr start/end logs around concrete technology calls. This overrides
# [debug].technology_logs_enabled in config.toml.
# Accepts: 1, true, yes, on.
# SRP_LOGS=1
