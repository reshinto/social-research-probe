  TitleSignal -- "unknown" --> LLM["LLM classifier"]
  LLM --> Parse["Parse structured_output from CLI envelope"]
  Parse --> Coerce["Coerce to valid class"]
  Coerce --> Result

  Result --> Output["primary | secondary | commentary | unknown"]

  subgraph Heuristic ["HeuristicClassifier (zero cost)"]
    Curated
    NameSignal
    TitleSignal
  end

  classDef input fill:#dbeafe,stroke:#2563eb,color:#111111,stroke-width:2px;
  classDef decision fill:#fef3c7,stroke:#d97706,color:#111111,stroke-width:2px;
