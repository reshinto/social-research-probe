sequenceDiagram
  participant Stage
  participant Service as BaseService subclass
  participant Tech as BaseTechnology subclass
  Stage->>Service: execute_batch(inputs)
  Service->>Service: execute_one checks service gate
  Service->>Tech: execute(technology_input)
