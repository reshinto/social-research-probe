flowchart TD
  Report["Completed report HTML"] --> Check{"Narration enabled?"}
  Check -- "no" --> Skip["Skip narration"]
  Check -- "yes" --> Extract["Extract text from report sections"]
  Extract --> Provider{"TTS provider"}
  Provider -- "mac" --> Mac["MacTTS"]
  Provider -- "voicebox" --> VBox["VoiceboxTTS"]
  Mac --> Audio["Audio file"]
  VBox --> Audio
  Audio --> Attach["Attach to report output"]

  classDef input fill:#dbeafe,stroke:#2563eb,color:#111111,stroke-width:2px;
  classDef decision fill:#fef3c7,stroke:#d97706,color:#111111,stroke-width:2px;
  classDef process fill:#f3f4f6,stroke:#6b7280,color:#111111,stroke-width:1px;
  classDef output fill:#dcfce7,stroke:#15803d,color:#111111,stroke-width:2px;

  class Report input
  class Check,Provider decision
  class Extract,Mac,VBox process
  class Skip,Audio,Attach output
