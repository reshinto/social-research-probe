# Copy to ~/.social-research-probe/config.toml (or pass --data-dir).
# Secrets live in a separate ~/.social-research-probe/secrets.toml (chmod 0600).
# The [llm].runner setting is the default runner for config-aware LLM features.
# See docs/data-directory.md for every file srp writes under ~/.social-research-probe/.

[llm]
runner = "none"           # claude | gemini | codex | local | none
timeout_seconds = 60

[llm.claude]
model = "sonnet"
extra_flags = []

[llm.gemini]
model = "gemini-2.5-pro"
extra_flags = []

[llm.codex]
binary = "codex"
model = "gpt-4o"
extra_flags = []

[llm.local]
binary = "ollama"
model = "llama3.1:8b"
extra_flags = []

[scoring.weights]
# Overrides for the spec §6 defaults used by overall_score:
#   trust = 0.45, trend = 0.30, opportunity = 0.25
# Uncomment + edit any subset to tune the trust/trend/opportunity trade-off.
# Per-purpose scoring_overrides (in purposes/*.json) take precedence over these.
# trust = 0.6
# trend = 0.2
# opportunity = 0.2

[corroboration]
backend = "auto"          # auto | llm_search | exa | brave | tavily | none
max_claims_per_item = 5
max_claims_per_session = 15

[platforms.youtube]
recency_days = 90
max_items = 20
enrich_top_n = 5          # number of top-scored videos that get transcripts + LLM summaries
cache_ttl_search_hours = 6
cache_ttl_channel_hours = 24

[stages.youtube]
# Highest priority. If a stage is false, everything inside that stage is skipped.
# Stage names map directly to the YouTubePipeline stage execution order.
fetch = true                 # Fetch YouTube search results.
score = true                 # Score and rank items by trust/trend/opportunity.
transcript = true            # Fetch transcripts for top-N items.
summary = true               # LLM per-item summaries for top-N items.
corroborate = true           # Corroborate claims via configured search backends.
stats = true                 # Statistical analysis on engagement and scores.
charts = true                # Chart generation from statistical results.
synthesis = true             # Final LLM research synthesis.
assemble = true              # Assemble research packet from stage outputs.
structured_synthesis = true  # Structured-JSON synthesis for report sections.
report = true                # HTML report generation.
narration = true             # Audio narration via Voicebox (or macOS TTS fallback).

[services.youtube.sourcing]
youtube = true            # YouTube Data API v3 search and metadata fetch.

[services.youtube.scoring]
score = true              # Trust/trend/opportunity scoring via overall_score().

[services.youtube.enriching]
transcript = true         # Transcript fetch: YouTube captions API, then yt-dlp + Whisper fallback.
summary = true            # LLM summary generation for each enriched item.

[services.youtube.corroborating]
corroborate = true        # Multi-backend web search to fact-check extracted claims.

[services.youtube.analyzing]
statistics = true         # Statistical analysis on engagement and scores.
charts = true             # Chart generation from statistical results.

[services.youtube.synthesizing]
synthesis = true          # Final LLM research synthesis from all stage outputs.

[services.youtube.reporting]
html = true               # HTML report generation.
audio = true              # Audio narration via Voicebox (or macOS TTS fallback).

# Legacy service gates used internally — do not remove.
[services.corroborate]
corroboration = true      # Enables corroboration backend health checks.

[services.enrich]
llm = true                # Enables LLM-based enrichment runner resolution.

[technologies]
# Lowest priority. Disable one provider/technology without disabling its peers.
# These represent actual implementations or external services.
youtube_api = true
youtube_transcript_api = true
whisper = true
yt_dlp = true             # yt-dlp audio download for Whisper fallback transcription.
voicebox = true
llm_search = true         # Runner-agnostic agentic-search corroboration backend.
exa = true
brave = true
tavily = true
claude = false             # Requires Anthropic account setup (claude CLI).
gemini = false             # Requires Google account setup (gemini CLI).
codex = false              # Requires OpenAI account setup (codex CLI).
local = false              # Requires a local LLM setup.

[tunables]
summary_divergence_threshold = 0.4   # transcript/URL summary divergence that triggers a warning
per_item_summary_words = 100         # target word count for per-item LLM summary

[debug]
technology_logs_enabled = true       # stderr start/end pairs around concrete technology calls
                                     # (override at runtime with SRP_LOGS=1)

[voicebox]
default_profile_name = "Jarvis"      # preferred Voicebox profile name for generated HTML reports
