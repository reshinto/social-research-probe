# Copy to ~/.social-research-probe/config.toml, or pass --data-dir to use a
# different data directory. Secrets belong in secrets.toml or SRP_* environment
# variables, not in this file. See docs/data-directory.md for storage details.

[llm]
# Default LLM runner used for summaries, synthesis, structured JSON tasks, and
# runner-backed search. "none" disables LLM calls while leaving fetch, scoring,
# statistics, charts, cache, and basic reports available.
runner = "none" # claude | gemini | codex | local | none

# Maximum wall-clock seconds allowed for one LLM subprocess call before srp
# kills it and continues with fallback behavior.
timeout_seconds = 60

[llm.claude]
# Extra arguments appended to every Claude CLI call. Use this for CLI-specific
# options such as model, permission, or profile flags supported by your local
# Claude Code installation.
extra_flags = ["--model", "claude-haiku-4-5"]

[llm.gemini]
# Extra arguments appended to every Gemini CLI call. Use this for CLI-specific
# options such as model or project flags supported by your local Gemini CLI.
extra_flags = ["--model", "gemini-2.5-flash-lite"]

[llm.codex]
# Codex CLI executable name or absolute path. The binary must support
# "codex exec" because srp invokes Codex in non-interactive mode.
binary = "codex"

# Extra arguments appended after "codex exec" and before the prompt. Use this
# for Codex-specific options such as model or sandbox flags supported by your
# installed Codex CLI.
extra_flags = ["--model", "gpt-5.4"]

[llm.local]
# No file-based defaults are used for the local runner yet. Set
# SRP_LOCAL_LLM_BIN in the environment to point at a wrapper that accepts a
# prompt on stdin and writes plain text to stdout.

[scoring.weights]
# Optional score weighting overrides for overall_score. The built-in defaults
# are trust=0.45, trend=0.30, and opportunity=0.25. Uncomment only the weights
# you want to override; per-purpose scoring_overrides still take precedence.
# trust = 0.6
# trend = 0.2
# opportunity = 0.2

[corroboration]
# Default provider for claim checks. "auto" chooses available configured
# providers; "llm_search" uses the active LLM runner's search tool; "none"
# disables corroboration.
provider = "auto" # auto | llm_search | exa | brave | tavily | none

# Maximum claims extracted from one research item before corroboration starts.
# Lower values reduce cost and runtime; higher values check more details.
max_claims_per_item = 5

# Maximum claims checked across one research run. This is the main guardrail for
# paid search APIs and runner-backed search costs.
max_claims_per_session = 15

[platforms.youtube]
# Only fetch videos published within this many days of the run.
recency_days = 90

# Maximum YouTube search results fetched before scoring and enrichment.
max_items = 20

# Number of top-scored videos that receive transcripts, summaries, and deeper
# enrichment. This controls most of the expensive or slow downstream work.
enrich_top_n = 5

[stages.youtube]
# Stage gates are the highest-priority switches. If a stage is false, srp skips
# that whole stage even if the service and technology gates below are true.
fetch = true                 # Fetch YouTube search results and metadata.
classify = true              # Classify each item's channel into a source_class label before scoring.
score = true                 # Rank items by trust, trend, and opportunity.
transcript = true            # Fetch captions or fallback transcripts.
summary = true               # Generate per-item LLM summaries.
corroborate = true           # Check extracted claims against search providers.
stats = true                 # Compute statistics from engagement and scores.
charts = true                # Render PNG charts from statistical results.
synthesis = true             # Generate final research synthesis.
assemble = true              # Assemble stage outputs into the report packet.
structured_synthesis = true  # Ask an LLM for structured report sections.
report = true                # Render the HTML report.
narration = true             # Render audio narration through Voicebox or fallback TTS.

[services.youtube.sourcing]
# Enables the YouTube sourcing service. Requires SRP_YOUTUBE_API_KEY or a
# youtube_api_key secret when live YouTube fetching is used.
youtube = true

[services.youtube.classifying]
# Enables source_class classification (primary | secondary | commentary |
# unknown) for each fetched item before scoring. When false, every item
# falls back to "unknown" without invoking any provider.
source_class = true

# Provider used for classification:
#   "heuristic" — curated channel map plus channel-name and title regex,
#                 zero cost. Items not in the map fall back to "unknown".
#   "llm"       — single LLM call per unknown channel via the active
#                 free-text runner. Requires the LLM service gate to be on
#                 and a runner enabled in [technologies].
#   "hybrid"    — heuristic first, LLM fallback for unknown channels.
provider = "hybrid"

[services.youtube.scoring]
# Enables trust/trend/opportunity scoring through overall_score().
score = true

[services.youtube.enriching]
# Enables transcript retrieval: captions first, then yt-dlp plus Whisper when
# captions are unavailable and the required tools are installed.
transcript = true

# Enables LLM-generated per-item summaries for enriched items.
summary = true

[services.youtube.corroborating]
# Enables claim extraction and provider-based corroboration.
corroborate = true

[services.youtube.analyzing]
# Enables numerical statistics over engagement and score fields.
statistics = true

# Enables chart rendering from the statistics and ranked result tables.
charts = true

[services.youtube.synthesizing]
# Enables final narrative synthesis from the assembled research evidence.
synthesis = true

[services.youtube.reporting]
# Enables HTML report generation under the active data directory.
html = true

# Enables audio report generation through Voicebox or local fallback TTS.
audio = true

[services.corroborate]
# Internal service gate still read by corroboration commands and health checks.
corroboration = true

[services.enrich]
# Internal service gate used before resolving LLM enrichment runners.
llm = true

[technologies]
# Enables source-class classification technologies (heuristic, LLM, hybrid).
# Set to false to skip all classification and leave source_class as "unknown".
classifying = true

# Enables YouTube Data API v3 calls for search and metadata. This requires a
# YouTube API key and consumes Google quota units.
youtube_api = true

# Enables public transcript fetching through youtube-transcript-api. This does
# not require an SRP API key, but it can be rate-limited or blocked by YouTube.
youtube_transcript_api = true

# Enables local Whisper fallback transcription after audio is downloaded.
whisper = true

# Enables yt-dlp audio download for Whisper fallback transcription.
yt_dlp = true

# Enables Voicebox TTS/report narration integration.
voicebox = true

# Enables runner-backed web search through Claude, Gemini, or Codex when the
# selected runner supports search tools.
llm_search = true

# Enables Exa as a paid/free-credit corroboration provider when an API key is
# configured.
exa = true

# Enables Brave Search as a paid/free-credit corroboration provider when an API
# key is configured.
brave = true

# Enables Tavily as a paid/free-credit corroboration provider when an API key is
# configured.
tavily = true

# Allows the Claude CLI runner. Keep false until Claude Code is installed and
# authenticated outside srp.
claude = false

# Allows the Gemini CLI runner. Keep false until Gemini CLI is installed and
# authenticated outside srp.
gemini = false

# Allows the Codex CLI runner. Keep false until Codex CLI is installed and
# authenticated outside srp.
codex = false

# Allows the local free-text runner. Set SRP_LOCAL_LLM_BIN before enabling.
local = false

# Enables the LLM ensemble enrichment technology for per-item summaries.
llm_ensemble = true

# Enables the LLM synthesis technology for generating the final research report.
llm_synthesis = true

# Enables the HTML report rendering technology.
html_render = true

# Enables per-target statistical analysis technology.
stats_per_target = true

# Enables the full chart suite generation technology.
charts_suite = true

# Enables the scoring computation technology for ranking items.
scoring_compute = true

# Enables the YouTube search technology (API-backed topic search).
youtube_search = true

# Enables the YouTube hydration technology (fetches video and channel statistics).
youtube_hydrate = true

# Enables the YouTube engagement metrics computation technology.
youtube_engagement = true

# Enables the corroboration host technology that runs all corroboration providers.
corroboration_host = true

# Enables macOS TTS narration for generated reports.
mac_tts = true

# Enables the claim extractor technology for identifying verifiable claims.
claim_extractor = true

# Enables the AI slop detector technology for filtering low-quality AI-generated content.
ai_slop_detector = true

[tunables]
# Transcript-vs-URL summary divergence threshold that triggers a warning.
summary_divergence_threshold = 0.4

# Target word count for each per-item LLM summary.
per_item_summary_words = 100

[debug]
# Enables stderr start/end logs around concrete technology calls. SRP_LOGS=1
# can enable the same logs at runtime without editing this file.
technology_logs_enabled = true

[voicebox]
# Preferred Voicebox profile name for generated HTML reports and narration.
default_profile_name = "Jarvis"

# Base URL for the local Voicebox API used by report playback and narration.
api_base = "http://127.0.0.1:17493"
