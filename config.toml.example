# Copy to ~/.social-research-probe/config.toml (or pass --data-dir).
# Secrets live in a separate ~/.social-research-probe/secrets.toml (chmod 0600).
# The [llm].runner setting is the default runner for config-aware LLM features.
# See docs/data-directory.md for every file srp writes under ~/.social-research-probe/.

[llm]
runner = "none"           # claude | gemini | codex | local | none
timeout_seconds = 60

[llm.claude]
model = "sonnet"
extra_flags = []

[llm.gemini]
model = "gemini-2.5-pro"
extra_flags = []

[llm.codex]
binary = "codex"
model = "gpt-4o"
extra_flags = []

[llm.local]
binary = "ollama"
model = "llama3.1:8b"
extra_flags = []

[scoring.weights]
# Overrides for the spec §6 defaults used by overall_score:
#   trust = 0.45, trend = 0.30, opportunity = 0.25
# Uncomment + edit any subset to tune the trust/trend/opportunity trade-off.
# Per-purpose scoring_overrides (in purposes/*.json) take precedence over these.
# trust = 0.6
# trend = 0.2
# opportunity = 0.2

[corroboration]
backend = "auto"          # auto | llm_search | exa | brave | tavily | none
max_claims_per_item = 5
max_claims_per_session = 15

[platforms.youtube]
recency_days = 90
max_items = 20
enrich_top_n = 5          # number of top-scored videos that get transcripts + LLM summaries
cache_ttl_search_hours = 6
cache_ttl_channel_hours = 24

[stages]
# Highest priority. If a stage is false, everything inside that stage is skipped.
fetch = true
score = true
enrich = true
corroborate = true
analyze = true
synthesis = true
report = true

[services.fetch]
# Services executed during the 'fetch' stage
platform_api = true        # Queries external APIs (e.g. YouTube) to find raw items and engagement metrics.

[services.score]
# Services executed during the 'score' stage
scoring = true             # Computes trend, trust, and opportunity scores for retrieved items.

[services.enrich]
# Services executed during the 'enrich' stage
transcripts = true         # Downloads transcripts/captions from videos (if available).
llm = true                 # General AI/LLM text generation and extraction for enrichment.
media_url_summary = true   # runner.summarize_media() (e.g. Gemini CLI extracting directly from video URL).
merged_summary = true      # Reconciles transcript-based and URL-based views into one combined summary.

[services.corroborate]
# Services executed during the 'corroborate' stage
corroboration = true       # Performs multi-backend web searches to fact-check extracted claims.

[services.analyze]
# Services executed during the 'analyze' stage
statistics = true          # Runs statistical analysis on engagement velocities and scores.
charts = true              # Renders visual charts (PNG/ASCII) based on pipeline metrics.
chart_takeaways = true     # Deterministic chart interpretations to give text-based takeaways.

[services.report]
# Services executed during the 'report' stage
html_report = true         # Generates a final HTML report summarizing the research.
audio_report = true        # Pre-renders Voicebox summary audio before HTML is written.

[technologies]
# Lowest priority. Disable one provider/technology without disabling its peers.
# These represent actual implementations or external services.
youtube_api = true
youtube_transcript_api = true
whisper = true
voicebox = true
llm_search = true          # Runner-agnostic agentic-search corroboration backend.
exa = true
brave = true
tavily = true
claude = false             # Requires Anthropic account setup.
gemini = false             # Requires Google account setup.
codex = false              # Requires OpenAI account setup.
local = false              # Requires a local LLM setup.

[tunables]
summary_divergence_threshold = 0.4   # transcript/URL summary divergence that triggers a warning
per_item_summary_words = 100         # target word count for merged per-item summary

[debug]
technology_logs_enabled = true       # stderr start/end pairs around concrete technology calls
                                     # (override at runtime with SRP_LOGS=1)

[voicebox]
default_profile_name = "Jarvis"      # preferred Voicebox profile name for generated HTML reports
