# Copy to ~/.social-research-probe/config.toml (or pass --data-dir).
# Secrets live in a separate ~/.social-research-probe/secrets.toml (chmod 0600).
# The [llm].runner setting is the default runner for config-aware LLM features.

[llm]
runner = "none"           # claude | gemini | codex | local | none
timeout_seconds = 60

[llm.claude]
model = "sonnet"
extra_flags = []

[llm.gemini]
model = "gemini-2.5-pro"
extra_flags = []

[llm.codex]
binary = "codex"
model = "gpt-4o"
extra_flags = []

[llm.local]
binary = "ollama"
model = "llama3.1:8b"
extra_flags = []

[scoring.weights]
# Overrides for the spec §6 defaults used by overall_score:
#   trust = 0.45, trend = 0.30, opportunity = 0.25
# Uncomment + edit any subset to tune the trust/trend/opportunity trade-off.
# Per-purpose scoring_overrides (in purposes/*.json) take precedence over these.
# trust = 0.6
# trend = 0.2
# opportunity = 0.2

[corroboration]
backend = "host"          # host | gemini_search | llm_cli | exa | brave | tavily | none
max_claims_per_item = 5
max_claims_per_session = 15

[platforms.youtube]
recency_days = 90
max_items = 20
enrich_top_n = 5          # number of top-scored videos that get transcripts + LLM summaries
cache_ttl_search_hours = 6
cache_ttl_channel_hours = 24

[features]
# Each toggle is independent: disabling one never breaks another. The final
# report is exempt and always emits (HTML when possible, Markdown fallback).
corroboration_enabled = true
gemini_search_enabled = true         # gemini --google-search backend (requires gemini CLI)
exa_enabled = true
brave_enabled = true
tavily_enabled = true
llm_cli_corroboration_enabled = true
enrichment_enabled = true
transcript_fetch_enabled = true
media_url_summary_enabled = true     # runner.summarize_media() (Gemini CLI only today)
merged_summary_enabled = true        # reconcile transcript + URL views into one 100-word summary
stats_enabled = true
charts_enabled = true
chart_takeaways_enabled = true       # deterministic 1-line chart interpretations
synthesis_enabled = true
html_report_enabled = true
markdown_report_enabled = true

# Per-LLM service gates. The primary runner (llm.runner above) is always
# allowed; these flags only affect whether each LLM is invoked as a secondary
# service (e.g. the ensemble fan-out used when the primary runner fails or
# when runner = "none" and multi-provider synthesis is desired). Disable any
# LLM you have installed but do not want srp to call from the ensemble.
# NOTE: gemini_service_enabled does NOT gate the Gemini web-search
# corroboration backend — that keeps its own gemini_search_enabled flag.
claude_service_enabled = true
gemini_service_enabled = true
codex_service_enabled = true
local_service_enabled = true

[tunables]
summary_divergence_threshold = 0.4   # transcript/URL summary divergence that triggers a warning
per_item_summary_words = 100         # target word count for merged per-item summary

[logging]
service_logs_enabled = false         # stderr start/end pairs for fetch/enrich/corroborate stages
                                     # (override at runtime with SRP_LOGS=1)
